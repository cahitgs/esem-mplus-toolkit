INPUT INSTRUCTIONS

  TITLE:
  Bifactor-ESEM (target orthogonal) - 3 specific factors
  DATA:
  FILE = "data1.dat";
  VARIABLE:
  NAMES ARE X1 X2 X3 X4 Y1 Y2 Y3 Y4 Z1 Z2 Z3 Z4 GROUP;
  USEVARIABLES ARE X1 X2 X3 X4 Y1 Y2 Y3 Y4 Z1 Z2 Z3 Z4;
  ANALYSIS:
  ESTIMATOR IS MLR;
  ROTATION=TARGET(ORTHOGONAL);
  MODEL:
  G BY X1 X2 X3 X4 Y1 Y2 Y3 Y4 Z1 Z2 Z3 Z4 (*1);
  F1 BY X1 X2 X3 X4 Y1~0 Y2~0 Y3~0 Y4~0 Z1~0 Z2~0 Z3~0 Z4~0 (*1);
  F2 BY X1~0 X2~0 X3~0 X4~0 Y1 Y2 Y3 Y4 Z1~0 Z2~0 Z3~0 Z4~0 (*1);
  F3 BY X1~0 X2~0 X3~0 X4~0 Y1~0 Y2~0 Y3~0 Y4~0 Z1 Z2 Z3 Z4 (*1);
  Z2 (res1);
  MODEL CONSTRAINT:
  res1 > 0;
  OUTPUT:
  SAMPSTAT STANDARDIZED RESIDUAL SVALUES CINTERVAL MODINDICES (3.0) TECH2 TECH4;



