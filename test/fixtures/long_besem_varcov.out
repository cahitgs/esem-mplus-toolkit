INPUT INSTRUCTIONS

  TITLE:
  Longitudinal invariance (bifactor-ESEM) - Factor var/cov
  DATA:
  FILE = "BLong.dat";
  VARIABLE:
  NAMES ARE x1_t1 x2_t1 x3_t1 x4_t1 y1_t1 y2_t1 y3_t1 y4_t1 z1_t1 z2_t1 z3_t1 z4_t1
    x1_t2 x2_t2 x3_t2 x4_t2 y1_t2 y2_t2 y3_t2 y4_t2 z1_t2 z2_t2 z3_t2 z4_t2;
  USEVARIABLES ARE x1_t1 x2_t1 x3_t1 x4_t1 y1_t1 y2_t1 y3_t1 y4_t1 z1_t1 z2_t1 z3_t1
    z4_t1 x1_t2 x2_t2 x3_t2 x4_t2 y1_t2 y2_t2 y3_t2 y4_t2 z1_t2 z2_t2 z3_t2 z4_t2;
  ANALYSIS:
  ESTIMATOR IS MLR;
  ROTATION=TARGET(ORTHOGONAL);
  ITERATIONS = 100000;
  MODEL:
  G1 BY x1_t1 x2_t1 x3_t1 x4_t1 y1_t1 y2_t1 y3_t1 y4_t1 z1_t1 z2_t1 z3_t1 z4_t1 (*t1 1);
  F1 BY x1_t1 x2_t1 x3_t1 x4_t1 y1_t1~0 y2_t1~0 y3_t1~0 y4_t1~0 z1_t1~0 z2_t1~0 z3_t1~0
    z4_t1~0 (*t1 1);
  F2 BY x1_t1~0 x2_t1~0 x3_t1~0 x4_t1~0 y1_t1 y2_t1 y3_t1 y4_t1 z1_t1~0 z2_t1~0 z3_t1~0
    z4_t1~0 (*t1 1);
  F3 BY x1_t1~0 x2_t1~0 x3_t1~0 x4_t1~0 y1_t1~0 y2_t1~0 y3_t1~0 y4_t1~0 z1_t1 z2_t1
    z3_t1 z4_t1 (*t1 1);
  G2 BY x1_t2 x2_t2 x3_t2 x4_t2 y1_t2 y2_t2 y3_t2 y4_t2 z1_t2 z2_t2 z3_t2 z4_t2 (*t2 1);
  F4 BY x1_t2 x2_t2 x3_t2 x4_t2 y1_t2~0 y2_t2~0 y3_t2~0 y4_t2~0 z1_t2~0 z2_t2~0 z3_t2~0
    z4_t2~0 (*t2 1);
  F5 BY x1_t2~0 x2_t2~0 x3_t2~0 x4_t2~0 y1_t2 y2_t2 y3_t2 y4_t2 z1_t2~0 z2_t2~0 z3_t2~0
    z4_t2~0 (*t2 1);
  F6 BY x1_t2~0 x2_t2~0 x3_t2~0 x4_t2~0 y1_t2~0 y2_t2~0 y3_t2~0 y4_t2~0 z1_t2 z2_t2
    z3_t2 z4_t2 (*t2 1);
  x1_t1 x2_t1 x3_t1 x4_t1 y1_t1 y2_t1 y3_t1 y4_t1 z1_t1 z2_t1 z3_t1 z4_t1 (u1-u12);
  x1_t2 x2_t2 x3_t2 x4_t2 y1_t2 y2_t2 y3_t2 y4_t2 z1_t2 z2_t2 z3_t2 z4_t2 (u1-u12);
  F4-F6@1;
  G2@1;
  G1 WITH F1 (lcov1);
  G2 WITH F4 (lcov1);
  G1 WITH F2 (lcov2);
  G2 WITH F5 (lcov2);
  G1 WITH F3 (lcov3);
  G2 WITH F6 (lcov3);
  F1 WITH F2 (lcov4);
  F4 WITH F5 (lcov4);
  F1 WITH F3 (lcov5);
  F4 WITH F6 (lcov5);
  F2 WITH F3 (lcov6);
  F5 WITH F6 (lcov6);
  [x1_t1 x2_t1 x3_t1 x4_t1 y1_t1 y2_t1 y3_t1 y4_t1 z1_t1 z2_t1 z3_t1 z4_t1] (i1-i12);
  [x1_t2 x2_t2 x3_t2 x4_t2 y1_t2 y2_t2 y3_t2 y4_t2 z1_t2 z2_t2 z3_t2 z4_t2] (i1-i12);
  [F1-F3@0];
  [G1@0];
  [F4-F6];
  [G2];
  x1_t1 WITH x1_t2;
  x2_t1 WITH x2_t2;
  x3_t1 WITH x3_t2;
  x4_t1 WITH x4_t2;
  y1_t1 WITH y1_t2;
  y2_t1 WITH y2_t2;
  y3_t1 WITH y3_t2;
  y4_t1 WITH y4_t2;
  z1_t1 WITH z1_t2;
  z2_t1 WITH z2_t2;
  z3_t1 WITH z3_t2;
  z4_t1 WITH z4_t2;
  OUTPUT:
  SAMPSTAT STANDARDIZED RESIDUAL CINTERVAL MODINDICES (3.0) TECH2 TECH4;



