  M22 M23 M24 (u22-u24);
  MODEL g2:
  F1*; F2*; F3*; F4*;
  [F1*]; [F2*]; [F3*]; [F4*];
  [M1 M2 M3 M4 M5 M6 M7 M8 M9 M10 M11 M12 M13 M14 M15 M16 M17 M18 M19 M20 M21] (i1-i21);
  [M22 M23 M24] (i22-i24);
  M1 M2 M3 M4 M5 M6 M7 M8 M9 M10 M11 M12 M13 M14 M15 M16 M17 M18 M19 M20 M21 (u1-u21);
  M22 M23 M24 (u22-u24);
