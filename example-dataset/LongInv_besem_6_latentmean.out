INPUT INSTRUCTIONS

  TITLE:
  Longitudinal invariance (bifactor-ESEM) - Latent means
  DATA:
  FILE = "iyiolus.dat";
  VARIABLE:
  NAMES ARE duy1_t1 duy2_t1 duy3_t1 duy4_t1 psi1_t1 psi2_t1 psi3_t1 psi4_t1 sos1_t1
    sos2_t1 sos3_t1 sos4_t1 duy1_t2 duy2_t2 duy3_t2 duy4_t2 psi1_t2 psi2_t2 psi3_t2
    psi4_t2 sos1_t2 sos2_t2 sos3_t2 sos4_t2 okul;
  USEVARIABLES ARE duy1_t1 duy2_t1 duy3_t1 duy4_t1 psi1_t1 psi2_t1 psi3_t1 psi4_t1
    sos1_t1 sos2_t1 sos3_t1 sos4_t1 duy1_t2 duy2_t2 duy3_t2 duy4_t2 psi1_t2 psi2_t2
    psi3_t2 psi4_t2 sos1_t2 sos2_t2 sos3_t2 sos4_t2;
  MISSING ARE ALL (999);
  ANALYSIS:
  ESTIMATOR IS MLR;
  ROTATION=TARGET(ORTHOGONAL);
  ITERATIONS = 100000;
  MODEL:
  G1 BY duy1_t1 duy2_t1 duy3_t1 duy4_t1 psi1_t1 psi2_t1 psi3_t1 psi4_t1 sos1_t1 sos2_t1
    sos3_t1 sos4_t1 (*t1 1);
  F1 BY duy1_t1 duy2_t1 duy3_t1 duy4_t1 psi1_t1~0 psi2_t1~0 psi3_t1~0 psi4_t1~0
    sos1_t1~0 sos2_t1~0 sos3_t1~0 sos4_t1~0 (*t1 1);
  F2 BY duy1_t1~0 duy2_t1~0 duy3_t1~0 duy4_t1~0 psi1_t1 psi2_t1 psi3_t1 psi4_t1
    sos1_t1~0 sos2_t1~0 sos3_t1~0 sos4_t1~0 (*t1 1);
  F3 BY duy1_t1~0 duy2_t1~0 duy3_t1~0 duy4_t1~0 psi1_t1~0 psi2_t1~0 psi3_t1~0 psi4_t1~0
    sos1_t1 sos2_t1 sos3_t1 sos4_t1 (*t1 1);
  G2 BY duy1_t2 duy2_t2 duy3_t2 duy4_t2 psi1_t2 psi2_t2 psi3_t2 psi4_t2 sos1_t2 sos2_t2
    sos3_t2 sos4_t2 (*t2 1);
  F4 BY duy1_t2 duy2_t2 duy3_t2 duy4_t2 psi1_t2~0 psi2_t2~0 psi3_t2~0 psi4_t2~0
    sos1_t2~0 sos2_t2~0 sos3_t2~0 sos4_t2~0 (*t2 1);
  F5 BY duy1_t2~0 duy2_t2~0 duy3_t2~0 duy4_t2~0 psi1_t2 psi2_t2 psi3_t2 psi4_t2
    sos1_t2~0 sos2_t2~0 sos3_t2~0 sos4_t2~0 (*t2 1);
  F6 BY duy1_t2~0 duy2_t2~0 duy3_t2~0 duy4_t2~0 psi1_t2~0 psi2_t2~0 psi3_t2~0 psi4_t2~0
    sos1_t2 sos2_t2 sos3_t2 sos4_t2 (*t2 1);
  duy1_t1 duy2_t1 duy3_t1 duy4_t1 psi1_t1 psi2_t1 psi3_t1 psi4_t1 sos1_t1 (u1-u9);
  sos2_t1 sos3_t1 sos4_t1 (u10-u12);
  duy1_t2 duy2_t2 duy3_t2 duy4_t2 psi1_t2 psi2_t2 psi3_t2 psi4_t2 sos1_t2 (u1-u9);
  sos2_t2 sos3_t2 sos4_t2 (u10-u12);
  F4-F6@1;
  G2@1;
  G1 WITH F1 (lcov1);
  G2 WITH F4 (lcov1);
  G1 WITH F2 (lcov2);
  G2 WITH F5 (lcov2);
  G1 WITH F3 (lcov3);
  G2 WITH F6 (lcov3);
  F1 WITH F2 (lcov4);
  F4 WITH F5 (lcov4);
  F1 WITH F3 (lcov5);
  F4 WITH F6 (lcov5);
  F2 WITH F3 (lcov6);
  F5 WITH F6 (lcov6);
  [duy1_t1 duy2_t1 duy3_t1 duy4_t1 psi1_t1 psi2_t1 psi3_t1 psi4_t1 sos1_t1] (i1-i9);
  [sos2_t1 sos3_t1 sos4_t1] (i10-i12);
  [duy1_t2 duy2_t2 duy3_t2 duy4_t2 psi1_t2 psi2_t2 psi3_t2 psi4_t2 sos1_t2] (i1-i9);
  [sos2_t2 sos3_t2 sos4_t2] (i10-i12);
  [F1-F3@0];
  [G1@0];
  [F4-F6@0];
  [G2@0];
  duy1_t1 WITH duy1_t2;
  duy2_t1 WITH duy2_t2;
  duy3_t1 WITH duy3_t2;
  duy4_t1 WITH duy4_t2;
  psi1_t1 WITH psi1_t2;
  psi2_t1 WITH psi2_t2;
  psi3_t1 WITH psi3_t2;
