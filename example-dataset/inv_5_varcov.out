INPUT INSTRUCTIONS

  TITLE:
  MG invariance - Factor var/cov
  DATA:
  FILE = "data.dat";
  VARIABLE:
  NAMES ARE M1 M2 M3 M4 M5 M6 M7 M8 M9 M10 M11 M12 M13 M14 M15 M16 M17 M18 M19 M20 M21
    M22 M23 M24 GRP;
  USEVARIABLES ARE M1 M2 M3 M4 M5 M6 M7 M8 M9 M10 M11 M12 M13 M14 M15 M16 M17 M18 M19
    M20 M21 M22 M23 M24;
  GROUPING IS GRP (1 = g1 2 = g2);
  ANALYSIS:
  ESTIMATOR IS MLR;
  ROTATION=GEOMIN(OBLIQUE, .5);
  ITERATIONS = 10000;
  MODEL:
  F1-F4 BY M1 M2 M3 M4 M5 M6 M7 M8 M9 M10 M11 M12 M13 M14 M15 M16 M17 M18 M19 M20 M21
    M22 M23 M24 (*1);
  F1-F4@1;
  F1 WITH F2 (cov1);
  F1 WITH F3 (cov2);
  F1 WITH F4 (cov3);
  F2 WITH F3 (cov4);
  F2 WITH F4 (cov5);
  F3 WITH F4 (cov6);
  [F1-F4@0];
  [M1 M2 M3 M4 M5 M6 M7 M8 M9 M10 M11 M12 M13 M14 M15 M16 M17 M18 M19 M20 M21] (i1-i21);
  [M22 M23 M24] (i22-i24);
  M1 M2 M3 M4 M5 M6 M7 M8 M9 M10 M11 M12 M13 M14 M15 M16 M17 M18 M19 M20 M21 (u1-u21);
  M22 M23 M24 (u22-u24);
  MODEL g2:
  F1-F4@1;
  F1 WITH F2 (cov1);
  F1 WITH F3 (cov2);
  F1 WITH F4 (cov3);
  F2 WITH F3 (cov4);
  F2 WITH F4 (cov5);
  F3 WITH F4 (cov6);
  [F1*]; [F2*]; [F3*]; [F4*];
  [M1 M2 M3 M4 M5 M6 M7 M8 M9 M10 M11 M12 M13 M14 M15 M16 M17 M18 M19 M20 M21] (i1-i21);
  [M22 M23 M24] (i22-i24);
  M1 M2 M3 M4 M5 M6 M7 M8 M9 M10 M11 M12 M13 M14 M15 M16 M17 M18 M19 M20 M21 (u1-u21);
  M22 M23 M24 (u22-u24);
  OUTPUT:
  SAMPSTAT STANDARDIZED RESIDUAL CINTERVAL MODINDICES (3.0) TECH2 TECH4;



INPUT READING TERMINATED NORMALLY




